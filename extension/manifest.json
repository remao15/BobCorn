{
  "manifest_version": 3,
  "name": "CartCop: BS Detector",
  "version": "2.0.0",
  "description": "Detects BS on any e-commerce page. Flags inconsistencies, bad policies, and surfaces verified alternatives.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://api.tavily.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CartCop BS Detector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
